# BagsTip API V1 Environment Variables
# Copy to .env and fill in real values. Do NOT commit .env.

SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# The vault keypair JSON array
ESCROW_PRIVATE_KEY=[1,2,3,...]
ESCROW_WALLET_ADDRESS=YOUR_ESCROW_PUBLIC_KEY

# Treasury wallet to receive 1.5% fees
TREASURY_WALLET_ADDRESS=YOUR_TREASURY_PUBLIC_KEY

# Solana RPC URL (e.g. Helius or QuickNode devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Twitter API v2 Bearer Token
X_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN

# Secret for bot communication
BOT_API_SECRET=super_secret_bot_key

# HTTP Server Port
PORT=3001
