# Environment Variables for BagsTip Claim API

# Server
PORT=3001

# Database
DB_PATH=./data/bagstip.db

# Verification Mode: "mock" or "real"
VERIFICATION_MODE=mock

# Contract Mode: "mock" or "real"
CONTRACT_MODE=mock

# Escrow Wallet (used for real contract calls)
ESCROW_WALLET_ADDRESS=

# RPC endpoint (for real Solana/EVM integration)
RPC_URL=

# X (Twitter) API credentials (for real verification)
X_BEARER_TOKEN=

# Secret for signing (optional)
API_SECRET=bagstip-dev-secret
